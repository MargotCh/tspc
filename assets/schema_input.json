{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/tanevskilab/tspc/master/assets/schema_input.json",
    "title": "tanevskilab/tspc pipeline - params.input schema",
    "description": "Schema for the file provided with params.input",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "sample": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "Sample name must be provided and cannot contain spaces",
                "meta": ["id"]
            },
            "image_path": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.(tif|tiff)$",
                "errorMessage": "Raw image or backsubed image must be provided, cannot contain spaces and must have extension '.tif' or '.tiff'"
            },
            "markersheet": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.(csv)$",
                "errorMessage": "Markersheet file must be provided"
            },
        },
        },
        "required": ["sample", "markersheet"]
    }
}
